    private final static Pattern NODOUBLEMARK = Pattern.compile("''");
    private final String MESSAGES = "messages";
    private static EcoUtils instance;
    private transient GreenBankMain greenBank;
    
    private transient Map<String, MessageFormat> messageFormatCache = new HashMap<>();
    //private transient Locale currentLocale = defaultLocale;
    private ResourceBundle NULL_BUNDLE = new ResourceBundle() {
        public Enumeration<String> getKeys() {
            return null;
        }

        protected Object handleGetObject(final String key) {
            return null;
        }
    };
    
    private ResourceBundle defaultBundle;
    private ResourceBundle customBundle;
    private ResourceBundle localeBundle;

    public EcoUtils(GreenBankMain greenBank) {
        this.greenBank = greenBank;
        defaultBundle = ResourceBundle.getBundle(MESSAGES, Locale.ENGLISH, new UTF8PropertiesControl());
        localeBundle = defaultBundle;
        customBundle = NULL_BUNDLE;
    }

    public static String tl(String string, Object[] objects) {
        CompletableFuture<String> future = CompletableFuture.supplyAsync(new Supplier<String>() {
            @Override
            public String get() {
                if (instance == null) {
                    return "";
                }
                if (objects.length == 0) {
                    return NODOUBLEMARK.matcher(EcoUtils.translate(string)).replaceAll("'");

                return EcoUtils.format(string, objects);
            }
        }});

        String result;

        try {
            result = future.get();
            return result;
        } catch (InterruptedException | ExecutionException e) {
            if (objects.length == 0) {
                return NODOUBLEMARK.matcher(EcoUtils.translate(string)).replaceAll("'");

            return EcoUtils.format(string, objects);
        }
    }
    
    public String format(final String string, final Object... objects) {
        String format = translate(string);
        MessageFormat messageFormat = messageFormatCache.get(format);
        if (messageFormat == null) {
            try {
                messageFormat = new MessageFormat(format);
            } catch (final IllegalArgumentException e) {
                greenBank.getLogger().log(Level.SEVERE, "Invalid Translation key for '" + string + "': " + e.getMessage());
                format = format.replaceAll("\\{(\\D*?)\\}", "\\[$1\\]");
                messageFormat = new MessageFormat(format);
            }
            messageFormatCache.put(format, messageFormat);
        }

        String msg = messageFormat.format(objects);

        return msg.replace(' ', ' '); // replace nbsp with a space
    }

